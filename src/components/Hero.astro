---
import HeroName from '../islands/HeroName.tsx';
---

<section id="hero" class="relative min-h-[100dvh] flex items-center pt-20 overflow-hidden">
  <div class="relative z-10 max-w-5xl mx-auto px-6 pb-20 flex flex-col items-center text-center">
    <div class="name-container relative">
      <h1
        class="hero-name tracking-tight md:tracking-[-0.04em] leading-[0.86] text-[clamp(2.4rem,8.4vw,5.4rem)] invisible pointer-events-none select-none whitespace-nowrap"
        aria-hidden="true"
      >
        Jayakrishnan PS
      </h1>
      <div class="absolute inset-0 flex items-center justify-center">
        <HeroName client:load />
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-4 mt-10 md:mt-12">
      <a href="#projects" class="btn btn-primary text-sm px-10 py-4 font-semibold">VIEW PROJECTS</a>
      <a href="#contact" class="btn btn-secondary text-sm px-10 py-4 font-semibold">GET IN TOUCH</a>
    </div>
  </div>
</section>
